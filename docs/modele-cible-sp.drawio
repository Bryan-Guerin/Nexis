<mxfile host="app.diagrams.net" type="device">
  <diagram id="nexis-sp-modele-cible" name="Modèle cible SP">
    <mxGraphModel dx="1100" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ── Titre ─────────────────────────────────────────────────────── -->
        <mxCell id="title" value="Nexis — Sapeurs-Pompiers : modèle cible (après V7)" style="text;html=1;fontSize=18;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="640" height="30" as="geometry" />
        </mxCell>

        <!-- ── Référentiels / catalogues ─────────────────────────────────── -->
        <mxCell id="ref_user" value="&lt;b&gt;ref_user&lt;/b&gt; (core)&lt;br&gt;──────────&lt;br&gt;id (PK)&lt;br&gt;username&lt;br&gt;password_hash" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="210" height="110" as="geometry" />
        </mxCell>

        <mxCell id="sp_grade" value="&lt;b&gt;sp_grade&lt;/b&gt;&lt;br&gt;──────────&lt;br&gt;id (PK)&lt;br&gt;code, label" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="210" height="90" as="geometry" />
        </mxCell>

        <!-- sp_fonction = catalogue des fonctions = des qualifications -->
        <mxCell id="sp_fonction" value="&lt;b&gt;sp_fonction&lt;/b&gt;&lt;br&gt;&lt;i&gt;catalogue des fonctions&lt;br&gt;= des qualifications&lt;/i&gt;&lt;br&gt;──────────&lt;br&gt;id (PK)&lt;br&gt;code, label" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="320" y="490" width="250" height="130" as="geometry" />
        </mxCell>

        <!-- ── Membre ────────────────────────────────────────────────────── -->
        <mxCell id="sp_membre" value="&lt;b&gt;sp_membre&lt;/b&gt;&lt;br&gt;&lt;i&gt;un user dans la faction SP&lt;/i&gt;&lt;br&gt;──────────&lt;br&gt;id (PK)&lt;br&gt;user_id (FK → ref_user)&lt;br&gt;grade_id (FK → sp_grade)&lt;br&gt;contrat (SPP/SPV)&lt;br&gt;numero_casier&lt;br&gt;numero_compteur, matricule&lt;br&gt;actif" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="320" y="50" width="250" height="190" as="geometry" />
        </mxCell>

        <!-- ── NOUVEAU : qualification = membre ↔ fonction (N–N) ──────────── -->
        <mxCell id="sp_membre_qualification" value="&lt;b&gt;sp_membre_qualification&lt;/b&gt;  &lt;span style=&quot;color:#2e7d32;&quot;&gt;★ V7&lt;/span&gt;&lt;br&gt;&lt;i&gt;qualification : le membre est&lt;br&gt;habilité à une fonction (N–N)&lt;/i&gt;&lt;br&gt;──────────&lt;br&gt;membre_id (PK, FK → sp_membre)&lt;br&gt;fonction_id (PK, FK → sp_fonction)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="320" y="300" width="250" height="140" as="geometry" />
        </mxCell>

        <!-- ── Type de véhicule + postes ─────────────────────────────────── -->
        <mxCell id="sp_vehicule_type" value="&lt;b&gt;sp_vehicule_type&lt;/b&gt;&lt;br&gt;&lt;i&gt;modèle d'engin (VSAV, FPT…)&lt;/i&gt;&lt;br&gt;──────────&lt;br&gt;id (PK)&lt;br&gt;code, label" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="700" y="300" width="270" height="110" as="geometry" />
        </mxCell>

        <mxCell id="sp_vehicule_type_poste" value="&lt;b&gt;sp_vehicule_type_poste&lt;/b&gt;&lt;br&gt;&lt;i&gt;poste d'un type ; requiert&lt;br&gt;une fonction ; nb_places&lt;/i&gt;&lt;br&gt;──────────&lt;br&gt;id (PK)&lt;br&gt;vehicule_type_id (FK → sp_vehicule_type)&lt;br&gt;fonction_id (FK → sp_fonction)&lt;br&gt;nb_places&lt;br&gt;UNIQUE(vehicule_type_id, fonction_id)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="700" y="470" width="290" height="160" as="geometry" />
        </mxCell>

        <!-- ── Véhicule (instance) + état ────────────────────────────────── -->
        <mxCell id="sp_vehicule" value="&lt;b&gt;sp_vehicule&lt;/b&gt;&lt;br&gt;&lt;i&gt;instance d'un type (un VSAV donné)&lt;/i&gt;&lt;br&gt;──────────&lt;br&gt;id (PK)&lt;br&gt;type_id (FK → sp_vehicule_type)&lt;br&gt;etat_id (FK → sp_vehicule_etat)&lt;br&gt;immatriculation, libelle, notes" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="700" y="50" width="290" height="160" as="geometry" />
        </mxCell>

        <mxCell id="sp_vehicule_etat" value="&lt;b&gt;sp_vehicule_etat&lt;/b&gt;&lt;br&gt;──────────&lt;br&gt;id (PK)&lt;br&gt;code, label, couleur" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="1080" y="50" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- ── Affectation : membre occupe un poste d'un véhicule ────────── -->
        <mxCell id="sp_vehicule_affectation" value="&lt;b&gt;sp_vehicule_affectation&lt;/b&gt;&lt;br&gt;&lt;i&gt;un membre occupe un poste d'un&lt;br&gt;véhicule (la fonction du poste),&lt;br&gt;sur une période&lt;/i&gt;&lt;br&gt;──────────&lt;br&gt;id (PK)&lt;br&gt;vehicule_id (FK → sp_vehicule)&lt;br&gt;membre_id (FK → sp_membre)&lt;br&gt;poste_id (FK → sp_vehicule_type_poste)&lt;br&gt;debut, fin" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="1080" y="280" width="300" height="220" as="geometry" />
        </mxCell>

        <!-- ── Relations ─────────────────────────────────────────────────── -->
        <mxCell id="e_membre_user" value="user_id  1..1" style="endArrow=ERone;startArrow=ERmany;html=1;fontSize=10;" edge="1" parent="1" source="sp_membre" target="ref_user">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_membre_grade" value="grade_id  N..1" style="endArrow=ERone;startArrow=ERmany;html=1;fontSize=10;" edge="1" parent="1" source="sp_membre" target="sp_grade">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_qual_membre" value="membre_id  N..1" style="endArrow=ERone;startArrow=ERmany;html=1;fontSize=10;" edge="1" parent="1" source="sp_membre_qualification" target="sp_membre">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_qual_fonction" value="fonction_id  N..1" style="endArrow=ERone;startArrow=ERmany;html=1;fontSize=10;strokeColor=#82b366;" edge="1" parent="1" source="sp_membre_qualification" target="sp_fonction">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_poste_type" value="vehicule_type_id  N..1" style="endArrow=ERone;startArrow=ERmany;html=1;fontSize=10;" edge="1" parent="1" source="sp_vehicule_type_poste" target="sp_vehicule_type">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_poste_fonction" value="requiert : fonction_id  N..1" style="endArrow=ERone;startArrow=ERmany;html=1;fontSize=10;strokeColor=#d6b656;" edge="1" parent="1" source="sp_vehicule_type_poste" target="sp_fonction">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_veh_type" value="type_id  N..1" style="endArrow=ERone;startArrow=ERmany;html=1;fontSize=10;" edge="1" parent="1" source="sp_vehicule" target="sp_vehicule_type">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_veh_etat" value="etat_id  N..1" style="endArrow=ERone;startArrow=ERmany;html=1;fontSize=10;" edge="1" parent="1" source="sp_vehicule" target="sp_vehicule_etat">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_aff_veh" value="vehicule_id  N..1" style="endArrow=ERone;startArrow=ERmany;html=1;fontSize=10;" edge="1" parent="1" source="sp_vehicule_affectation" target="sp_vehicule">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_aff_membre" value="membre_id  N..1" style="endArrow=ERone;startArrow=ERmany;html=1;fontSize=10;" edge="1" parent="1" source="sp_vehicule_affectation" target="sp_membre">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_aff_poste" value="poste_id  N..1" style="endArrow=ERone;startArrow=ERmany;html=1;fontSize=10;" edge="1" parent="1" source="sp_vehicule_affectation" target="sp_vehicule_type_poste">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── Légende ───────────────────────────────────────────────────── -->
        <mxCell id="legend" value="&lt;b&gt;Légende&lt;/b&gt;&lt;br&gt;★ V7 = table ajoutée (remplace sp_qualification)&lt;br&gt;&lt;br&gt;• Fonction = catalogue des qualifications&lt;br&gt;• Qualification = membre ↔ fonction (sp_membre_qualification)&lt;br&gt;• Poste de type = requiert une fonction&lt;br&gt;• Affectation = membre occupe le poste d'un véhicule&lt;br&gt;&nbsp;&nbsp;(et donc la fonction du poste), sur une période" style="text;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#ffffff;strokeColor=#cccccc;" vertex="1" parent="1">
          <mxGeometry x="40" y="490" width="250" height="160" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
