# Copier en `.env` puis adapter. NE PAS committer le .env réel.

# Image Docker à déployer (registre Docker Hub). Utilisée sur le VPS pour le pull.
# Format : <utilisateur-dockerhub>/nexis:latest
NEXIS_IMAGE=bryanguerin/nexis:latest

# Base de données
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-db-password

# ── Reverse-proxy Caddy / TLS ────────────────────────────────────────────────
# Domaine servi (HTTPS automatique Let's Encrypt si domaine public + ports 80/443
# ouverts pointant vers ce serveur). Test local : localhost  ou  :80 (HTTP seul).
NEXIS_DOMAIN=localhost
# E-mail pour les notifications Let's Encrypt (recommandé en prod).
ACME_EMAIL=

# Port de l'app si on l'expose en direct (debug). Par défaut l'app n'est PAS
# publiée : seul Caddy l'est (80/443). Décommenter le bloc `ports` de `app` pour s'en servir.
APP_PORT=8080

# Secret de signature JWT (HS256) — minimum 32 caractères aléatoires.
# Générer p.ex. avec :  openssl rand -base64 48
JWT_GENERATOR_SIGNATURE_SECRET=change-me-with-a-long-random-secret-min-32-chars

# Options JVM optionnelles (mémoire, GC…)
# JAVA_OPTS=-Xmx512m
