# Copier en `.env` puis adapter. NE PAS committer le .env réel.

# Image Docker à déployer (registre Docker Hub). Utilisée sur le VPS pour le pull.
# Format : <utilisateur-dockerhub>/nexis:latest
NEXIS_IMAGE=bryanguerin/nexis:latest

# Base de données — PostgreSQL tourne en SERVICE SYSTÈME sur l'hôte (pas en conteneur).
# Ces identifiants doivent correspondre au user/base créés sur l'hôte (base : nexis).
# Le conteneur joint l'hôte via host.docker.internal (configuré dans docker-compose.yaml).
POSTGRES_USER=nexis
POSTGRES_PASSWORD=change-me-strong-db-password

# UID/GID du user hôte (nexis) qui doit posséder les logs écrits dans le volume.
# Récupère-les sur le VPS avec :  id -u   et   id -g   (souvent 1000/1000).
PUID=1000
PGID=1000

# Port exposé directement par l'app (sans Caddy). Accès : http://<IP_VPS>:8080
# Quand tu passes au profil https, couper ce port dans docker-compose.yaml.
APP_PORT=8080

# ── Reverse-proxy Caddy / TLS (profil "https") ──────────────────────────────
# Activer avec : docker compose --profile https up -d
# Prérequis : domaine public pointant sur le VPS, ports 80 et 443 ouverts.
NEXIS_DOMAIN=nexis.mondomaine.fr
# E-mail pour les notifications Let's Encrypt (obligatoire avec le profil https).
ACME_EMAIL=moi@exemple.fr

# Secret de signature JWT (HS256) — minimum 32 caractères aléatoires.
# Générer p.ex. avec :  openssl rand -base64 48
JWT_GENERATOR_SIGNATURE_SECRET=change-me-with-a-long-random-secret-min-32-chars

# Options JVM optionnelles (mémoire, GC…)
# JAVA_OPTS=-Xmx512m
