<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Properties>
        <Property name="PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%X{user}] %-40logger{40} %msg%n</Property>
        <!-- Surchargeable via -DLOG_DIR=... (prod : volume monté). Défaut dev : ./logs.
             NB : la property NE DOIT PAS s'appeler LOG_DIR (collision avec sys:LOG_DIR →
             boucle infinie d'interpolation au démarrage). -->
        <Property name="LOG_PATH">${sys:LOG_DIR:-logs}</Property>
    </Properties>

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${PATTERN}"/>
        </Console>

        <!-- 1 fichier de log par jour. Rétention : 10 jours OU 2 Go cumulés (le 1er atteint). -->
        <RollingFile name="File"
                     fileName="${LOG_PATH}/nexis.log"
                     filePattern="${LOG_PATH}/nexis-%d{yyyy-MM-dd}.log.gz">
            <PatternLayout pattern="${PATTERN}"/>
            <Policies>
                <!-- modulate : bascule à minuit pile -->
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
            </Policies>
            <DefaultRolloverStrategy>
                <Delete basePath="${LOG_PATH}" maxDepth="1">
                    <IfFileName glob="nexis-*.log.gz">
                        <IfAny>
                            <IfLastModified age="10d"/>
                            <IfAccumulatedFileSize exceeds="2 GB"/>
                        </IfAny>
                    </IfFileName>
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- Code applicatif Nexis : INFO en prod, passer à DEBUG pour diagnostiquer -->
        <Logger name="com.bryan.nexis" level="info" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Logger>

        <!-- Frameworks : bruit réduit, mais persistés aussi dans nexis.log (logs de démarrage inclus) -->
        <Logger name="io.micronaut"  level="info" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Logger>
        <Logger name="org.hibernate" level="warn" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Logger>
        <Logger name="org.flywaydb"  level="info" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Logger>

        <Root level="warn">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Root>
    </Loggers>

</Configuration>
